          </datasources>
          <datasource-dependencies datasource='federated.1jtntgg0gim1511dmdio401pmwdd'>
            <column caption='Trip ID' datatype='string' name='[Trip_ID]' role='dimension' type='nominal' />
            <column-instance column='[Trip_ID]' derivation='Count' name='[cnt:Trip_ID:qk]' pivot='key' type='quantitative' />
            <column-instance column='[start_area]' derivation='None' name='[none:start_area:nk]' pivot='key' type='nominal' />
            <column-instance column='[traffic_density_level]' derivation='None' name='[none:traffic_density_level:nk]' pivot='key' type='nominal' />
            <column caption='Start Area' datatype='string' name='[start_area]' role='dimension' type='nominal' />
            <column caption='Traffic Density Level' datatype='string' name='[traffic_density_level]' role='dimension' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1jtntgg0gim1511dmdio401pmwdd].[none:start_area:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='COUNT([Trip_ID])' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:start_area:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.1jtntgg0gim1511dmdio401pmwdd].[none:traffic_density_level:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:traffic_density_level:nk]' member='&quot;High&quot;' />
              <groupfilter function='member' level='[none:traffic_density_level:nk]' member='&quot;Very High&quot;' />
            </groupfilter>
          </filter>
          <shelf-sorts>
